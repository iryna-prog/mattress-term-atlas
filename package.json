{
  "name": "mattress-term-atlas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "generate:data": "node scripts/build-keyword-library.mjs",
    "validate:data": "node scripts/validate-keyword-library.mjs",
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev --host 0.0.0.0",
    "build": "tsc -b && WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "preview": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start --host 0.0.0.0",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start --host 0.0.0.0"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "react-server-dom-webpack": "19.2.6",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  }
}
